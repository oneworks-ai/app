{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "oneworks-relay-server",
  "main": "cloudflare/worker.ts",
  "compatibility_date": "2026-06-01",
  "compatibility_flags": [
    "nodejs_compat",
  ],
  "durable_objects": {
    "bindings": [
      {
        "name": "RELAY_OBJECT",
        "class_name": "RelayDurableObject",
      },
    ],
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": [
        "RelayDurableObject",
      ],
    },
  ],
}
