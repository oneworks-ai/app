{
  "name": "@oneworks/plugin-relay",
  "__oneWorksPluginManifest": true,
  "displayName": "Account",
  "type": "module",
  "version": "0.1.0-beta.5",
  "repository": {
    "type": "git",
    "url": "https://github.com/oneworks-ai/app.git",
    "directory": "packages/plugins/relay"
  },
  "config": {
    "schema": {
      "type": "object",
      "titleI18n": {
        "en": "Account options",
        "zh-Hans": "账号选项"
      },
      "descriptionI18n": {
        "en": "Connect this workspace service to OneWorks Relay services.",
        "zh-Hans": "把当前工作区服务连接到 OneWorks Relay 服务。"
      },
      "properties": {
        "activeServerId": {
          "type": "string",
          "titleI18n": {
            "en": "Active server",
            "zh-Hans": "默认连接服务"
          },
          "descriptionI18n": {
            "en": "Default server id from the servers list.",
            "zh-Hans": "servers 列表里的默认连接服务 id。"
          },
          "x-oneworks-ui": {
            "icon": "radio_button_checked",
            "placeholder": "oneworks-cloudflare"
          }
        },
        "enableOfficialCloudflareRelay": {
          "type": "boolean",
          "default": true,
          "titleI18n": {
            "en": "OneWorks Cloudflare Relay",
            "zh-Hans": "OneWorks Cloudflare Relay"
          },
          "descriptionI18n": {
            "en": "Show and enable the official OneWorks Relay service hosted on Cloudflare.",
            "zh-Hans": "显示并启用托管在 Cloudflare 的 OneWorks 官方 Relay 服务。"
          },
          "x-oneworks-ui": {
            "icon": "cloud"
          }
        },
        "enableOfficialVercelRelay": {
          "type": "boolean",
          "default": true,
          "titleI18n": {
            "en": "OneWorks Vercel Relay",
            "zh-Hans": "OneWorks Vercel Relay"
          },
          "descriptionI18n": {
            "en": "Show and enable the official OneWorks Relay service hosted on Vercel.",
            "zh-Hans": "显示并启用托管在 Vercel 的 OneWorks 官方 Relay 服务。"
          },
          "x-oneworks-ui": {
            "icon": "deployed_code"
          }
        },
        "servers": {
          "type": "array",
          "titleI18n": {
            "en": "Relay servers",
            "zh-Hans": "认证链接服务列表"
          },
          "descriptionI18n": {
            "en": "Additional private or custom relay systems this device can connect to.",
            "zh-Hans": "当前设备可连接的额外私有或自定义 Relay 系统。"
          },
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "name": {
                "type": "string"
              },
              "server": {
                "type": "string"
              },
              "port": {
                "type": "number"
              },
              "protocol": {
                "type": "string",
                "enum": [
                  "https",
                  "http"
                ]
              },
              "baseUrl": {
                "type": "string"
              },
              "pairingToken": {
                "type": "string",
                "format": "password"
              }
            }
          },
          "x-oneworks-ui": {
            "icon": "hub"
          }
        },
        "deviceName": {
          "type": "string",
          "titleI18n": {
            "en": "Device name",
            "zh-Hans": "设备名称"
          },
          "descriptionI18n": {
            "en": "Name shown in the relay device list.",
            "zh-Hans": "在 Relay 设备列表里展示的名称。"
          },
          "x-oneworks-ui": {
            "icon": "devices",
            "placeholder": "Office Mac"
          }
        },
        "autoConnect": {
          "type": "boolean",
          "default": false,
          "titleI18n": {
            "en": "Auto connect",
            "zh-Hans": "自动连接"
          },
          "descriptionI18n": {
            "en": "Register with the configured relay when the plugin starts.",
            "zh-Hans": "插件启动时自动向配置的 Relay 注册。"
          },
          "x-oneworks-ui": {
            "icon": "power_settings_new"
          }
        },
        "exposeSessions": {
          "type": "boolean",
          "default": true,
          "titleI18n": {
            "en": "Expose sessions",
            "zh-Hans": "开放会话"
          },
          "descriptionI18n": {
            "en": "Allow the relay to list and forward chat sessions for this device.",
            "zh-Hans": "允许 Relay 查询并转发当前设备上的聊天会话。"
          },
          "x-oneworks-ui": {
            "icon": "forum"
          }
        },
        "exposeTerminal": {
          "type": "boolean",
          "default": false,
          "titleI18n": {
            "en": "Expose terminal",
            "zh-Hans": "开放终端"
          },
          "descriptionI18n": {
            "en": "Advertise terminal access capability to the relay. Keep disabled unless the remote service is trusted.",
            "zh-Hans": "向 Relay 声明终端访问能力；仅在信任远端服务时开启。"
          },
          "x-oneworks-ui": {
            "icon": "terminal"
          }
        },
        "exposeWorkspaceFiles": {
          "type": "boolean",
          "default": false,
          "titleI18n": {
            "en": "Expose workspace files",
            "zh-Hans": "开放工作区文件"
          },
          "descriptionI18n": {
            "en": "Advertise workspace file access capability to the relay.",
            "zh-Hans": "向 Relay 声明工作区文件访问能力。"
          },
          "x-oneworks-ui": {
            "icon": "folder_open"
          }
        }
      }
    }
  },
  "configHook": {
    "entry": "./dist/config.cjs"
  },
  "plugin": {
    "client": {
      "root": "dist/client",
      "entry": "dist/client/index.js"
    },
    "contributions": {
      "cliCommands": [
        {
          "id": "login",
          "path": [
            "login"
          ],
          "root": true,
          "command": "login",
          "titleI18n": {
            "en": "Login",
            "zh-Hans": "登录"
          },
          "descriptionI18n": {
            "en": "Sign in to a OneWorks account. Defaults to -s cf.",
            "zh-Hans": "登录 OneWorks 账号；默认使用 -s cf。"
          }
        },
        {
          "id": "logout",
          "path": [
            "logout"
          ],
          "root": true,
          "command": "logout",
          "titleI18n": {
            "en": "Logout",
            "zh-Hans": "退出登录"
          },
          "descriptionI18n": {
            "en": "Remove a local OneWorks account login.",
            "zh-Hans": "移除本机 OneWorks 账号登录态。"
          }
        },
        {
          "id": "users",
          "path": [
            "users"
          ],
          "root": true,
          "command": "users",
          "titleI18n": {
            "en": "Users",
            "zh-Hans": "用户"
          },
          "descriptionI18n": {
            "en": "List local OneWorks account logins.",
            "zh-Hans": "列出本机 OneWorks 账号登录态。"
          }
        },
        {
          "id": "users-enable",
          "path": [
            "users",
            "enable"
          ],
          "root": true,
          "command": "users-enable",
          "titleI18n": {
            "en": "Enable user",
            "zh-Hans": "启用用户"
          },
          "descriptionI18n": {
            "en": "Enable a local OneWorks account for this daemon.",
            "zh-Hans": "启用本机 OneWorks 账号供当前 daemon 使用。"
          }
        },
        {
          "id": "users-disable",
          "path": [
            "users",
            "disable"
          ],
          "root": true,
          "command": "users-disable",
          "titleI18n": {
            "en": "Disable user",
            "zh-Hans": "停用用户"
          },
          "descriptionI18n": {
            "en": "Disable a local OneWorks account without deleting its login.",
            "zh-Hans": "停用本机 OneWorks 账号，但保留登录态。"
          }
        }
      ],
      "routes": [
        {
          "id": "home",
          "title": "Account",
          "titleI18n": {
            "en": "Account",
            "zh-Hans": "账号"
          },
          "icon": "account_circle",
          "clientView": "home"
        }
      ],
      "launcherSearchProviders": [
        {
          "id": "relay",
          "title": "Account",
          "titleI18n": {
            "en": "Account",
            "zh-Hans": "账号"
          },
          "command": "search"
        }
      ]
    }
  },
  "exports": {
    ".": "./package.json",
    "./client": {
      "source": "./src/client/index.ts",
      "default": "./dist/client/index.js"
    },
    "./server": {
      "source": "./src/server/index.ts",
      "default": "./dist/server/index.js"
    },
    "./config": {
      "__oneworks__": {
        "import": "./src/config.ts",
        "require": "./src/config.cts"
      },
      "default": {
        "import": "./dist/config.js",
        "require": "./dist/config.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "README.md",
    "dist",
    "package.json",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepublish": "pnpm build",
    "test": "pnpm -C ../../.. exec vitest run --workspace vitest.workspace.ts --project bundler packages/plugins/relay/__tests__",
    "typecheck": "tsc -p tsconfig.json --noEmit --pretty false"
  },
  "dependencies": {
    "@oneworks/components": "workspace:*",
    "@oneworks/utils": "workspace:*",
    "ws": "^8.17.0"
  },
  "devDependencies": {
    "@types/ws": "^8.18.1"
  }
}
