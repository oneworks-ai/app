{
  "compilerOptions": {
    "target": "ES2022",
    "jsx": "react",
    "jsxFactory": "h",
    "lib": ["ES2022", "DOM"],
    "rootDir": "src",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": false,
    "outDir": "dist",
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"]
}
