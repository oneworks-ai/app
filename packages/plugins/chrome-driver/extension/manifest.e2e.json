{
  "manifest_version": 3,
  "key": "",
  "name": "oneWorks External Browser (E2E)",
  "version": "0.1.0",
  "description": "Isolated-profile test flavor. Not for user installation.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "activeTab",
    "alarms",
    "bookmarks",
    "browsingData",
    "contentSettings",
    "cookies",
    "debugger",
    "downloads",
    "downloads.open",
    "history",
    "management",
    "pageCapture",
    "privacy",
    "proxy",
    "readingList",
    "scripting",
    "sessions",
    "storage",
    "system.display",
    "tabGroups",
    "tabs",
    "webNavigation"
  ],
  "host_permissions": ["<all_urls>"],
  "background": { "service_worker": "background.js", "type": "module" },
  "content_scripts": [{
    "matches": ["http://127.0.0.1/*", "http://localhost/*"],
    "js": ["content-script.js"],
    "run_at": "document_start"
  }],
  "web_accessible_resources": [{
    "resources": ["agent-cursor.svg", "default-tab-favicon.svg"],
    "matches": ["<all_urls>"]
  }],
  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    },
    "default_popup": "popup.html",
    "default_title": "oneWorks External Browser"
  }
}
