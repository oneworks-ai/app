{
  "name": "@oneworks/plugin-chrome-devtools",
  "displayName": "Chrome DevTools",
  "displayNameI18n": {
    "en": "Chrome DevTools",
    "zh-Hans": "Chrome 开发者工具"
  },
  "version": "0.1.0-beta.7",
  "repository": {
    "type": "git",
    "url": "https://github.com/oneworks-ai/app.git",
    "directory": "packages/plugins/chrome-devtools"
  },
  "imports": {
    "#~/*.js": {
      "__oneworks__": {
        "default": "./src/*.ts"
      },
      "default": {
        "import": "./dist/index.mjs",
        "require": "./dist/index.js"
      }
    }
  },
  "exports": {
    ".": {
      "__oneworks__": {
        "default": "./src/index.ts"
      },
      "default": {
        "import": "./dist/index.mjs",
        "require": "./dist/index.js"
      }
    },
    "./hooks": {
      "__oneworks__": {
        "default": "./src/hooks.ts"
      },
      "default": {
        "import": "./dist/hooks.mjs",
        "require": "./dist/hooks.js"
      }
    },
    "./schema": {
      "__oneworks__": {
        "default": "./src/schema.ts"
      },
      "default": {
        "import": "./dist/schema.mjs",
        "require": "./dist/schema.js"
      }
    },
    "./package.json": "./package.json"
  },
  "icon": "./assets/icon.svg",
  "dependencies": {
    "@oneworks/core": "workspace:*",
    "@oneworks/hooks": "workspace:*",
    "@oneworks/types": "workspace:*"
  }
}
