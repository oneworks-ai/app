{
  "name": "@oneworks/plugin-logger",
  "displayName": "Logger",
  "displayNameI18n": {
    "en": "Logger",
    "zh-Hans": "日志"
  },
  "descriptionI18n": {
    "en": "Structured runtime logging and diagnostics for OneWorks plugins.",
    "zh-Hans": "为 OneWorks 插件提供结构化运行日志与诊断能力。"
  },
  "version": "0.1.0-beta.8",
  "description": "Structured runtime logging and diagnostics for OneWorks plugins.",
  "repository": {
    "type": "git",
    "url": "https://github.com/oneworks-ai/app.git",
    "directory": "packages/plugins/logger"
  },
  "imports": {
    "#~/*.js": {
      "__oneworks__": {
        "default": "./src/*.ts"
      },
      "default": {
        "import": "./dist/index.mjs",
        "require": "./dist/index.js"
      }
    }
  },
  "exports": {
    ".": {
      "__oneworks__": {
        "default": "./src/index.ts"
      },
      "default": {
        "import": "./dist/index.mjs",
        "require": "./dist/index.js"
      }
    },
    "./hooks": {
      "__oneworks__": {
        "default": "./src/hooks.ts"
      },
      "default": {
        "import": "./dist/hooks.mjs",
        "require": "./dist/hooks.js"
      }
    },
    "./package.json": "./package.json"
  },
  "icon": "./assets/icon.svg",
  "dependencies": {
    "@oneworks/core": "workspace:*",
    "@oneworks/hooks": "workspace:*",
    "@oneworks/types": "workspace:*"
  }
}
