{
  "name": "@oneworks/cursor",
  "type": "commonjs",
  "version": "0.1.0-beta.7",
  "description": "Reusable OneWorks pointer cursor SVG renderer",
  "repository": {
    "type": "git",
    "url": "https://github.com/oneworks-ai/app.git",
    "directory": "packages/cursor"
  },
  "exports": {
    ".": {
      "types": "./index.d.cts",
      "import": "./index.mjs",
      "require": "./index.cjs",
      "default": "./index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "README.md",
    "index.cjs",
    "index.d.cts",
    "index.mjs"
  ],
  "scripts": {
    "test": "pnpm -C ../.. exec vitest run --workspace vitest.workspace.ts --project bundler packages/cursor/__tests__"
  }
}
