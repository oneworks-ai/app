{
  "name": "@oneworks/runtime-store",
  "version": "0.1.0-alpha.0",
  "description": "Local file runtime store for One Works agent sessions",
  "repository": {
    "type": "git",
    "url": "https://github.com/oneworks-ai/app.git",
    "directory": "packages/runtime-store"
  },
  "imports": {
    "#~/*.js": {
      "__oneworks__": {
        "default": "./src/*.ts"
      },
      "default": {
        "import": "./dist/*.mjs",
        "require": "./dist/*.js"
      }
    }
  },
  "exports": {
    ".": {
      "__oneworks__": {
        "default": "./src/index.ts"
      },
      "default": {
        "import": "./dist/index.mjs",
        "require": "./dist/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "test": "pnpm -C ../.. exec vitest run --workspace vitest.workspace.ts --project bundler packages/runtime-store/__tests__",
    "typecheck": "pnpm -C ../.. exec tsc -p packages/runtime-store/tsconfig.json --noEmit --pretty false"
  },
  "dependencies": {
    "@oneworks/runtime-protocol": "workspace:^",
    "@oneworks/utils": "workspace:*"
  }
}
