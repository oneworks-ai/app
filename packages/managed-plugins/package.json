{
  "name": "@oneworks/managed-plugins",
  "version": "0.1.0-beta.1",
  "description": "Managed native plugin installation and sync for One Works",
  "repository": {
    "type": "git",
    "url": "https://github.com/oneworks-ai/app.git",
    "directory": "packages/managed-plugins"
  },
  "imports": {
    "#~/*.js": {
      "__oneworks__": {
        "default": "./src/*.ts"
      },
      "default": {
        "import": "./dist/*.mjs",
        "require": "./dist/*.js"
      }
    }
  },
  "exports": {
    ".": {
      "__oneworks__": {
        "default": "./src/index.ts"
      },
      "default": {
        "import": "./dist/index.mjs",
        "require": "./dist/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "test": "pnpm -C ../.. exec vitest run --workspace vitest.workspace.ts --project bundler packages/managed-plugins/__tests__"
  },
  "dependencies": {
    "@oneworks/config": "workspace:*",
    "@oneworks/types": "workspace:*",
    "@oneworks/utils": "workspace:*"
  }
}
