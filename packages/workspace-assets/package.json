{
  "name": "@oneworks/workspace-assets",
  "version": "0.1.0-alpha.0",
  "description": "Workspace asset resolution and adapter asset planning for OneWorks",
  "repository": {
    "type": "git",
    "url": "https://github.com/oneworks-ai/app.git",
    "directory": "packages/workspace-assets"
  },
  "imports": {
    "#~/*.js": {
      "__oneworks__": {
        "default": "./src/*.ts"
      },
      "default": {
        "import": "./dist/*.mjs",
        "require": "./dist/*.js"
      }
    }
  },
  "exports": {
    ".": {
      "__oneworks__": {
        "default": "./src/index.ts"
      },
      "default": {
        "import": "./dist/index.mjs",
        "require": "./dist/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "test": "pnpm -C ../.. exec vitest run --workspace vitest.workspace.ts --project bundler packages/workspace-assets/__tests__"
  },
  "dependencies": {
    "@oneworks/config": "workspace:*",
    "@oneworks/definition-core": "workspace:*",
    "@oneworks/types": "workspace:*",
    "@oneworks/utils": "workspace:*",
    "fast-glob": "^3.3.3",
    "front-matter": "^4.0.2",
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9"
  }
}
