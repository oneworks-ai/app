{
  "name": "@oneworks/avatar",
  "type": "module",
  "version": "0.1.0-beta.7",
  "description": "OneWorks avatar pixel emoticon SVG renderer",
  "repository": {
    "type": "git",
    "url": "https://github.com/oneworks-ai/app.git",
    "directory": "packages/avatar"
  },
  "imports": {
    "#~/*.js": {
      "__oneworks__": {
        "default": "./src/*.ts"
      },
      "default": "./dist/*.js"
    }
  },
  "exports": {
    ".": {
      "__oneworks__": {
        "default": "./src/index.ts"
      },
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./avatar": {
      "__oneworks__": {
        "default": "./src/avatar.ts"
      },
      "types": "./dist/avatar.d.ts",
      "default": "./dist/avatar.js"
    },
    "./seed": {
      "__oneworks__": {
        "default": "./src/seed.ts"
      },
      "types": "./dist/seed.d.ts",
      "default": "./dist/seed.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "pnpm -C ../.. exec vitest run --workspace vitest.workspace.ts --project bundler packages/avatar/__tests__"
  }
}
