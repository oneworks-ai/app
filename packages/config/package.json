{
  "name": "@oneworks/config",
  "version": "0.1.0-alpha.0",
  "description": "Shared config IO for One Works",
  "repository": {
    "type": "git",
    "url": "https://github.com/oneworks-ai/app.git",
    "directory": "packages/config"
  },
  "imports": {
    "#~/*.js": {
      "__oneworks__": {
        "default": "./src/*.ts"
      },
      "default": {
        "import": "./dist/*.mjs",
        "require": "./dist/*.js"
      }
    }
  },
  "exports": {
    ".": {
      "__oneworks__": {
        "default": "./src/index.ts"
      },
      "default": {
        "import": "./dist/index.mjs",
        "require": "./dist/index.js"
      }
    },
    "./schema": {
      "__oneworks__": {
        "default": "./src/schema.ts"
      },
      "default": {
        "import": "./dist/schema.mjs",
        "require": "./dist/schema.js"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "test": "pnpm -C ../.. exec vitest run --workspace vitest.workspace.ts --project bundler packages/config/__tests__"
  },
  "dependencies": {
    "@oneworks/core": "workspace:*",
    "@oneworks/types": "workspace:*",
    "@oneworks/utils": "workspace:*",
    "js-yaml": "^4.1.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9"
  }
}
