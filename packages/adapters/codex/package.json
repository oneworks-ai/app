{
  "name": "@oneworks/adapter-codex",
  "version": "0.1.0-beta.5",
  "description": "Codex App Server Adapter for One Works",
  "repository": {
    "type": "git",
    "url": "https://github.com/oneworks-ai/app.git",
    "directory": "packages/adapters/codex"
  },
  "imports": {
    "#~/*.js": {
      "__oneworks__": {
        "default": "./src/*.ts"
      },
      "default": {
        "import": "./dist/*.mjs",
        "require": "./dist/*.js"
      }
    }
  },
  "exports": {
    ".": {
      "__oneworks__": {
        "default": "./src/index.ts"
      },
      "default": {
        "import": "./dist/index.mjs",
        "require": "./dist/index.js"
      }
    },
    "./schema": {
      "__oneworks__": {
        "default": "./src/schema.ts"
      },
      "default": {
        "import": "./dist/schema.mjs",
        "require": "./dist/schema.js"
      }
    },
    "./config-schema": {
      "__oneworks__": {
        "default": "./src/config-schema.ts"
      },
      "default": {
        "import": "./dist/config-schema.mjs",
        "require": "./dist/config-schema.js"
      }
    },
    "./cli-prepare": {
      "__oneworks__": {
        "default": "./src/cli-prepare.ts"
      },
      "default": {
        "import": "./dist/cli-prepare.mjs",
        "require": "./dist/cli-prepare.js"
      }
    },
    "./models": {
      "__oneworks__": {
        "default": "./src/models.ts"
      },
      "default": {
        "import": "./dist/models.mjs",
        "require": "./dist/models.js"
      }
    },
    "./model-provider-import": {
      "__oneworks__": {
        "default": "./src/model-provider-import.ts"
      },
      "default": {
        "import": "./dist/model-provider-import.mjs",
        "require": "./dist/model-provider-import.js"
      }
    },
    "./worktree-environment-import": {
      "__oneworks__": {
        "default": "./src/worktree-environment-import.ts"
      },
      "default": {
        "import": "./dist/worktree-environment-import.mjs",
        "require": "./dist/worktree-environment-import.js"
      }
    },
    "./icon": {
      "__oneworks__": {
        "default": "./src/icon.ts"
      },
      "default": {
        "import": "./dist/icon.mjs",
        "require": "./dist/icon.js"
      }
    },
    "./hook-bridge": {
      "__oneworks__": {
        "default": "./src/hook-bridge.ts"
      },
      "default": {
        "import": "./dist/hook-bridge.mjs",
        "require": "./dist/hook-bridge.js"
      }
    },
    "./plugins": {
      "__oneworks__": {
        "default": "./src/plugins/index.ts"
      },
      "default": {
        "import": "./dist/plugins/index.mjs",
        "require": "./dist/plugins/index.js"
      }
    },
    "./native-plugins": {
      "__oneworks__": {
        "default": "./src/native-plugins/index.ts"
      },
      "default": {
        "import": "./dist/native-plugins/index.mjs",
        "require": "./dist/native-plugins/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "dependencies": {
    "@oneworks/adapter-claude-code": "workspace:*",
    "@oneworks/config": "workspace:*",
    "@oneworks/core": "workspace:*",
    "@oneworks/hooks": "workspace:*",
    "@oneworks/register": "workspace:*",
    "@oneworks/types": "workspace:*",
    "@oneworks/utils": "workspace:*",
    "smol-toml": "^1.7.0",
    "zod": "^3.24.1"
  }
}
