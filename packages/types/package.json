{
  "name": "@oneworks/types",
  "version": "0.1.0-beta.8",
  "description": "Shared types for One Works",
  "repository": {
    "type": "git",
    "url": "https://github.com/oneworks-ai/app.git",
    "directory": "packages/types"
  },
  "exports": {
    ".": {
      "__oneworks__": {
        "default": "./src/index.ts"
      },
      "default": {
        "import": "./dist/index.mjs",
        "require": "./dist/index.js"
      }
    },
    "./standalone-route": {
      "__oneworks__": {
        "default": "./src/standalone-route.ts"
      },
      "default": {
        "import": "./dist/standalone-route.mjs",
        "require": "./dist/standalone-route.js"
      }
    },
    "./package.json": "./package.json"
  }
}
