{
  "name": "oneworks-dev",
  "version": "0.1.0-beta.7",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "desktop:dev": "pnpm tools dev-service ensure electron",
    "desktop:dev:workspace": "pnpm tools dev-service ensure electron-workspace",
    "dev:docs": "pnpm tools dev-service ensure docs",
    "dev:homepage": "pnpm tools dev-service ensure homepage",
    "dev:pwa": "pnpm tools dev-service ensure pwa",
    "dev:web": "pnpm tools dev-service ensure web",
    "desktop:icons:sync": "pnpm -C apps/desktop icons:sync",
    "desktop:make": "pnpm -C apps/desktop make",
    "desktop:make:pkg": "pnpm -C apps/desktop make:pkg",
    "desktop:make:pkg:icon": "pnpm -C apps/desktop make:pkg:icon",
    "desktop:make:pkg:from-package": "pnpm -C apps/desktop make:pkg:from-package",
    "desktop:make:pkg:icon:from-package": "pnpm -C apps/desktop make:pkg:icon:from-package",
    "desktop:package": "pnpm -C apps/desktop package",
    "desktop:package:icon": "pnpm -C apps/desktop package:icon",
    "start": "pnpm tools dev-service ensure web",
    "tools": "node ./scripts/run-tools.mjs",
    "test:e2e:adapters": "pnpm tools adapter-e2e test",
    "test:e2e:relay-local-sso": "pnpm -C apps/relay-server test:e2e:local-sso",
    "test:e2e:relay-web-electron": "pnpm -C packages/plugins/relay test -- client-callback && pnpm -C apps/desktop test -- deep-link",
    "typecheck": "node ./scripts/typecheck.mjs",
    "typebuild": "pnpm exec tsc -b --pretty false",
    "typebuild:clean": "pnpm exec tsc -b --clean",
    "vscode:compile": "pnpm -C apps/vscode-extension compile",
    "vscode:package": "pnpm -C apps/vscode-extension package",
    "vscode:publish": "pnpm -C apps/vscode-extension publish:vsix"
  },
  "dependencies": {
    "luna-console": "^1.3.6",
    "luna-data-grid": "^1.6.5",
    "luna-dom-highlighter": "^1.0.2",
    "luna-dom-viewer": "^1.8.4",
    "luna-object-viewer": "^0.3.2"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^6.0.0",
    "@mizchi/lsmcp": "^0.10.0",
    "@oneworks/adapter-claude-code": "workspace:*",
    "@oneworks/adapter-codex": "workspace:*",
    "@oneworks/adapter-copilot": "workspace:*",
    "@oneworks/adapter-gemini": "workspace:*",
    "@oneworks/adapter-kimi": "workspace:*",
    "@oneworks/adapter-opencode": "workspace:*",
    "@oneworks/cli": "workspace:*",
    "@oneworks/client": "workspace:*",
    "@oneworks/plugin-browser-driver": "workspace:*",
    "@oneworks/plugin-chrome-driver": "workspace:*",
    "@oneworks/plugin-cua-driver": "workspace:*",
    "@oneworks/plugin-demo": "workspace:*",
    "@oneworks/plugin-demo-extension": "workspace:*",
    "@oneworks/plugin-logger": "workspace:*",
    "@oneworks/plugin-relay": "workspace:*",
    "@oneworks/plugin-standard-dev": "workspace:*",
    "@oneworks/server": "workspace:*",
    "@oneworks/task": "workspace:*",
    "@oneworks/utils": "workspace:*",
    "@types/node": "^22.18.12",
    "@typescript/native-preview": "7.0.0-dev.20260115.1",
    "baseline-browser-mapping": "2.10.13",
    "commander": "^12.1.0",
    "dprint": "^0.50.2",
    "esbuild-register": "^3.6.0",
    "eslint": "^9.38.0",
    "proper-lockfile": "4.1.2",
    "typescript": "^5.9.3",
    "vitest": "^2.0.5"
  }
}
